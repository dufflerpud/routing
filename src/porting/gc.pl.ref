#!/usr/bin/perl -w

use strict;

use Geo::StreetAddress::US;

sub normalize
    {
    my( $r ) = Geo::StreetAddress::US->parse_informal_address(join(",",@_));
    my $res = join(",",
	join(" ",$r->{number}||"",$r->{street},$r->{type}),
	$r->{city}||"",
	$r->{state}||"",
	$r->{zip}||"" );
    $res =~ s/\s+/ /g;
    $res =~ s/,\s*,/,/g;
    $res=$1 if( $res =~ /^,*(.*?),*$/ );
    return $res;
    }

print &normalize( @ARGV ), "\n";

exit(0);
