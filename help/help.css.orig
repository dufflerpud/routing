body		{
		font-family: Arial, Helvetica, sans-serif;
		cursor:default;
		margin-left: 0px;
		margin-top: 0px;
		margin-right: 0px;
		margin-bottom: 0px;
		Qbackground-color: #6090b0;
		Qcolor: white;
		}

@media (max-width:1200px) {
	body		{ font-size: 45px; }
	td		{ font-size: 1em; }
	th		{ font-size: 1em; }
	.helpfoot	{ font-size: 50px; }
	input[type=checkbox]	{ width:40px; height:40px; }
}

@media print {
    body	{
    		color: black;
		background-color: white;
    }
    tbody	{
		color: #204080;
		background-color: white;
		}
    details	{
    		open:	true;
		}
    }

@media not print {
    body	{
    		background-color: #70a0c0;
		color: white;
		}
    tbody	{
		background-color: #D0F0FF;
		color: #204080;
		}
    }

A:link		{ color: #af2020; text-decoration: underline;	}
A:active	{ color: #20af20; text-decoration: underline;	}
A:visited	{ color: #2020af; text-decoration: underline;	}
A:hover		{ color: #ffa0a0; text-decoration: blink;	}

.field_format	{
		Qtext-indent:		50px;
		font-family:		monospace;
		Qbackground-color:	#D0F0FF;
		color:			#000000;
		}

.helpfoot	{
		background-color:	lightblue;
		}

details		{
		margin-left:		auto;
		margin-right:		auto;
		padding:		3px;
		border:			1px solid black;
		background-color:	#b4daef;
		color:			#204060;
		width:			95%;
		align:			center;
		}

summary		{
		Qmargin-left:		-5em;
		background-color:	#2196c3;
		color:			white;
		padding:		3px;
		}
